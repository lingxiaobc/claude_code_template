{
    "model": "sonnet",
    "availableModels": [
        "sonnet",
        "opus",
        "haiku",
        "opusplan"
    ],
    "effortLevel": "high",
    "env": {
        "ANTHROPIC_BASE_URL": "YOUR_API_BASE_URL",
        "ANTHROPIC_AUTH_TOKEN": "YOUR_AUTH_TOKEN",
        "ANTHROPIC_DEFAULT_OPUS_MODEL": "opus-model-name",
        "ANTHROPIC_DEFAULT_SONNET_MODEL": "sonnet-model-name",
        "ANTHROPIC_DEFAULT_HAIKU_MODEL": "haiku-model-name",
        "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS":"1",
        "ANTHROPIC_DEFAULT_HAIKU_MODEL": "haiku-model-name",
        "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "0",
        "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
        "CLAUDE_CODE_DISABLE_1M_CONTEXT": "0",
        "CLAUDE_CODE_EFFORT_LEVEL": "high",
        "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
        "OTEL_METRICS_EXPORTER": "otlp"
    },
    "permissions": {
        "allow": []
    }
}